{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.26/MicrosoftTeams.schema.json",
  "manifestVersion": "1.27",
  "version": "1.0.12",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "My App, Inc.",
    "websiteUrl": "https://www.example.com",
    "privacyUrl": "https://www.example.com/privacy",
    "termsOfUseUrl": "https://www.example.com/termsofuse"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "SignalTuner${{APP_NAME_SUFFIX}}",
    "full": "SignalTuner for Microsoft Teams"
  },
  "description": {
    "short": "Join a SignalTuner meeting health view.",
    "full": "SignalTuner lets authenticated users in a Teams meeting join a shared meeting health view and share their own connectivity status."
  },
  "accentColor": "#FFFFFF",
  "supportsChannelFeatures": "tier1",
  "bots": [
  {
    "botId": "d3f0801c-8c8e-4c90-a3b0-cee3c1c40fea",
    "scopes": ["personal", "groupChat", "team"],
    "isNotificationOnly": false,
    "supportsFiles": false
  }
],
"webApplicationInfo": {
        "id": "e9e69ad8-84c2-4469-9697-949c54b98f09",
        "resource": "api://localhost:3978/e9e69ad8-84c2-4469-9697-949c54b98f09"
}
,
  "composeExtensions": [],
  "staticTabs": [
    {
      "entityId": "home",
      "name": "SignalTuner",
      "contentUrl": "${{TAB_ENDPOINT}}/tabs/home",
      "websiteUrl": "${{TAB_ENDPOINT}}/tabs/home",
      "scopes": ["personal"],
      "context": ["personalTab"]
    }
  ],
  "configurableTabs": [
    {
      "configurationUrl": "${{TAB_ENDPOINT}}/tabs/config",
      "canUpdateConfiguration": true,
      "scopes": ["groupChat", "team"],
      "context": [
        "meetingChatTab",
        "meetingDetailsTab",
        "meetingSidePanel"
      ]
    }
  ],
  "meetingExtensionDefinition": {
    "scenes": [],
    "supportsStreaming": false
  },
  "permissions": ["identity"],
  "validDomains": [
    "teams.signaltuner.com",
    "www.signaltuner.com",
    "signaltuner-back.azurewebsites.net"
  ],
  "authorization": {
    "permissions": {
      "resourceSpecific": []
    }
  }
      }
